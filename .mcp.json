{
  "mcpServers": {
    "flights": {
      "command": "/Users/nescao/.local/bin/uv",
      "args": [
        "--directory",
        "/Users/nescao/Documents/GitHub/flights-mcp-server",
        "run",
        "flights.py"
      ]
    },
    "apify-trip-hotels": {
      "command": "npx",
      "args": [
        "mcp-remote",
        "https://mcp.apify.com/?tools=hotels-scrapers/trip-hotel-scraper",
        "--header",
        "Authorization: Bearer <YOUR_API_TOKEN>"
      ]
    }
  }
}
